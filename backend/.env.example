APP_ENV=development
VIDEO_UPLOAD_DIR=storage/uploads
OAUTH_SESSION_DIR=storage/oauth_sessions
FRAME_SAMPLE_SECONDS=3
CORS_ORIGINS=["http://localhost:3000"]
MAX_TITLE_COUNT=2
UPLOAD_SESSION_TTL_SECONDS=3600
OAUTH_SESSION_TTL_SECONDS=2592000
FRONTEND_BASE_URL=http://localhost:3000
BROWSER_SESSION_COOKIE_SAMESITE=lax
BROWSER_SESSION_COOKIE_SECURE=false
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/youtube/callback
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=
