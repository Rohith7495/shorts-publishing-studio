APP_ENV=production
VIDEO_UPLOAD_DIR=/opt/shorts-publishing-studio/backend/storage/uploads
OAUTH_SESSION_DIR=/opt/shorts-publishing-studio/backend/storage/oauth_sessions
FRAME_SAMPLE_SECONDS=3
CORS_ORIGINS=["https://your-project.vercel.app"]
MAX_TITLE_COUNT=2
UPLOAD_SESSION_TTL_SECONDS=3600
OAUTH_SESSION_TTL_SECONDS=2592000
FRONTEND_BASE_URL=https://your-project.vercel.app
BROWSER_SESSION_COOKIE_SAMESITE=none
BROWSER_SESSION_COOKIE_SECURE=true
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://api.your-backend-domain.example/api/auth/youtube/callback
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-2.5-flash-lite
